{
  "name": "life-grid-apk",
  "version": "1.0.0",
  "private": true,
  "description": "PILLARS Life Grid - pure client-side PWA wrapped as an Android APK using Capacitor",
  "scripts": {
    "serve": "npx http-server ./www -p 5173 -c-1",
    "cap:add:android": "npx cap add android",
    "cap:sync": "npx cap sync",
    "android:debug": "cd android && ./gradlew assembleDebug",
    "android:release": "cd android && ./gradlew assembleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^6.1.2",
    "@capacitor/core": "^6.1.2",
    "@capacitor/app": "^6.0.1",
    "@capacitor/filesystem": "^6.0.1",
    "@capacitor/share": "^6.0.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.2",
    "http-server": "^14.1.1",
    "@capacitor/assets": "^3.0.5"
  }
}